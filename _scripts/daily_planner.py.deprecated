from google.auth.transport.requests import Request
from google.oauth2.credentials import Credentials
from google_auth_oauthlib.flow import InstalledAppFlow
from googleapiclient.discovery import build
import base64
import requests
from msal import ConfidentialClientApplication

# Paths
ENVIRONMENTS_PATH = r'G:\My Drive\03_Areas\Keys\Environments\environments.json'
GMAIL_TOKEN_PATH = r'G:\My Drive\03_Areas\Keys\Gmail\token.json'
GMAIL_SCOPES = [
    'https://www.googleapis.com/auth/gmail.readonly',
    'https://www.googleapis.com/auth/calendar.readonly',
    'https://www.googleapis.com/auth/drive.readonly'
]
GDRIVE_SCOPES = ['https://www.googleapis.com/auth/drive.readonly']
MICROSOFT_SCOPES = ['https://graph.microsoft.com/.default']

class DailyPlanner:
    def __init__(self):
        # Load environment config
        with open(ENVIRONMENTS_PATH, 'r') as f:
            self.env_config = json.load(f)
        
        self.todoist_token = self.env_config['environments']['todoist']['credentials']['apiToken']
        self.gmail_service = None
        self.calendar_service = None
        self.drive_service = None
        self.ms_token = None
        
        # Microsoft 365 credentials
        ms_config = self.env_config['environments']['microsoft365']
        self.ms_client_id = ms_config['oauth']['clientId']
        self.ms_client_secret = ms_config['oauth']['clientSecret']
        self.ms_tenant_id = ms_config['oauth']['tenantId']
        
        # Unimportant senders to skip
        self.skip_senders = [
            'tiktok.com', 'noreply', 'no-reply', 'donotreply',
            'marketing@', 'promo@', 'newsletter@', 'notifications@',
            'redditmail.com', 'email.monarch.com', 'rescueme.org',
            'govdelivery.com', 'membershipto', 'bankofamerica.com',
            'ealerts.', 'USPSInformeddelivery', 'schwab.com',
            'creditkarma.com', 'omadahealth.com',
            # Politicians and government updates
            'congressman', 'senator', 'representative', 'house.gov',
            'senate.gov', 'whitehouse.gov', 'campaign@', 'political',
            # Shipping/delivery notifications
            'amazon.com', 'shipment-tracking@', 'ship-confirm@',
            'auto-confirm@', 'order-update@', 'delivery@',
            'fedex.com', 'ups.com', 'usps.com', 'dhl.com',
            'tracking@', 'shipping@', 'shippo.com',
            # Personal exclusions
            'alexandra hartnett', 'hartnett'
        ]
        
        # Keywords to skip (newsletters, updates, generic announcements)
        self.skip_keywords = [
            # Shipping
            'shipped', 'delivered', 'delivery', 'tracking',
            'package', 'shipment', 'order confirmation',
            'your order', 'has shipped', 'out for delivery',
            'hanger', 'hangers', 'item has been delivered',
            # Generic updates/newsletters
            'sharing important updates', 'weekly update', 'monthly update',
            'newsletter', 'this week in', 'latest news',
            'unsubscribe', 'update from', 'updates from',
            'important updates', 'sharing updates'
        ]
        
        # Reference email patterns (important info to save)
        self.reference_patterns = [
            'account number', 'account #', 'account:', 'acct #',
            'confirmation number', 'confirmation code', 'confirmation #',
            'reference number', 'reference #', 'ref #',
            'policy number', 'policy #', 'claim number', 'case number',
            'username:', 'password:', 'login:', 'credentials',
            'activation code', 'verification code', 'access code',
            'membership number', 'member #', 'customer id', 'customer number',
            'order number', 'order #', 'invoice #', 'invoice number',
            'hoa', 'homeowners association', 'property account'
        ]
        
        self.reference_emails = []
        
        # Track authentication status
        self.auth_status = {
            'gmail': self.authenticate_gmail(),
            'google_drive': self.authenticate_google_drive(),
            'microsoft': self.authenticate_microsoft()
        }
    
    def authenticate_gmail(self):
        """Authenticate with Gmail API - auto-triggers OAuth if needed"""
        creds = None
        gmail_creds_path = r'G:\My Drive\03_Areas\Keys\Gmail\credentials.json'
        
        # Try to load existing token
        if os.path.exists(GMAIL_TOKEN_PATH):
            creds = Credentials.from_authorized_user_file(GMAIL_TOKEN_PATH, GMAIL_SCOPES)
        
        # Refresh or re-authenticate if needed
        if not creds or not creds.valid:
            if creds and creds.expired and creds.refresh_token:
                try:
                    creds.refresh(Request())
                    print("✅ Gmail token refreshed")
                except Exception as e:
                    print(f"⚠️  Token refresh failed: {e}")
                    creds = None
            
            # If still no valid creds, trigger OAuth flow
            if not creds and os.path.exists(gmail_creds_path):
                try:
                    print("🔐 Starting Gmail OAuth flow...")
                    flow = InstalledAppFlow.from_client_secrets_file(gmail_creds_path, GMAIL_SCOPES)
                    creds = flow.run_local_server(port=0)
                    print("✅ Gmail OAuth successful")
                except Exception as e:
                    print(f"❌ Gmail OAuth failed: {e}")
                    return False
            
            # Save the credentials for next time
            if creds:
                os.makedirs(os.path.dirname(GMAIL_TOKEN_PATH), exist_ok=True)
                with open(GMAIL_TOKEN_PATH, 'w') as token:
                    token.write(creds.to_json())
        
        if creds and creds.valid:
            self.gmail_service = build('gmail', 'v1', credentials=creds)
            self.calendar_service = build('calendar', 'v3', credentials=creds)
            print("✅ Gmail & Calendar authenticated")
            return True
        else:
            print("❌ Gmail authentication failed")
            return False
    
    def authenticate_google_drive(self):
        """Authenticate with Google Drive API"""
        try:
            if os.path.exists(GMAIL_TOKEN_PATH):
                creds = Credentials.from_authorized_user_file(GMAIL_TOKEN_PATH, GDRIVE_SCOPES)
                
                if creds and creds.valid:
                    self.drive_service = build('drive', 'v3', credentials=creds)
                    print("✅ Google Drive authenticated")
                    return True
                else:
                    print("❌ Google Drive token expired")
                    return False
        except Exception as e:
            print(f"❌ Google Drive authentication failed: {e}")
            return False
    
    def authenticate_microsoft(self):
        """Authenticate with Microsoft Graph API using delegated token"""
        try:
            ms_token_path = r'G:\My Drive\03_Areas\Keys\Microsoft365\token.json'
            
            if os.path.exists(ms_token_path):
                with open(ms_token_path, 'r') as f:
                    token_data = json.load(f)
                    self.ms_token = token_data.get('access_token')
                    print("✅ Microsoft 365 authenticated (delegated)")
                    return True
            else:
                print("❌ Microsoft 365 token not found")
                return False
        except Exception as e:
            print(f"❌ Microsoft 365 authentication failed: {e}")
            return False
    
    def is_important_sender(self, sender):
        """Check if email is from important sender"""
        sender_lower = sender.lower()
        for skip_pattern in self.skip_senders:
            if skip_pattern in sender_lower:
                return False
        return True
    
    def is_unimportant_email(self, subject, body):
        """Check if email is shipping/delivery notification or generic newsletter"""
        text = (subject + ' ' + body).lower()
        return any(keyword in text for keyword in self.skip_keywords)
    
    def get_outlook_emails(self, days=14):
        """Get urgent emails from Outlook/Microsoft 365"""
        if not self.ms_token:
            return []
        
        try:
            headers = {'Authorization': f'Bearer {self.ms_token}'}
            after_date = (datetime.now(timezone.utc) - timedelta(days=days)).isoformat()
            
            # Query for emails from last 2 weeks
            url = f"https://graph.microsoft.com/v1.0/me/messages?$filter=receivedDateTime ge {after_date}&$top=50&$select=subject,from,receivedDateTime,bodyPreview,hasAttachments"
            response = requests.get(url, headers=headers)
            
            if response.status_code == 200:
                messages = response.json().get('value', [])
                urgent_items = []
                
                for msg in messages:
                    sender = msg.get('from', {}).get('emailAddress', {}).get('address', '')
                    
                    if not self.is_important_sender(sender):
                        continue
                    
                    subject = msg.get('subject', '')
                    body = msg.get('bodyPreview', '')
                    
                    if self.is_unimportant_email(subject, body):
                        continue
                    
                    text = (subject + ' ' + body).lower()
                    is_urgent = any(word in text for word in [
                        'urgent', 'asap', 'today', 'deadline', 'due',
                        'important', 'action required', 'respond', 'confirm'
                    ])
                    
                    if is_urgent:
                        urgent_items.append({
                            'title': subject,
                            'source': f"Outlook from {sender.split('@')[0]}",
                            'due': self.extract_due_date(text),
                            'priority': 'high' if 'urgent' in text or 'asap' in text else 'normal'
                        })
                
                return urgent_items[:5]
            else:
                print(f"⚠️  Outlook API error: {response.status_code}")
                return []
        except Exception as e:
            print(f"⚠️  Error fetching Outlook emails: {e}")
            return []
    
    def get_gmail_emails(self, days=30):
        """Get urgent emails from Gmail"""
        try:
            # Search for emails from last 1 month (for testing)
            one_month_ago = (datetime.now() - timedelta(days=days)).strftime('%Y/%m/%d')
            query = f'after:{one_month_ago} -category:promotions -category:social'
            
            results = self.gmail_service.users().messages().list(
                userId='me',
                q=query,
                maxResults=50
            ).execute()
            
            messages = results.get('messages', [])
            urgent_items = []
            
            for msg in messages:
                email = self.get_email_details(msg['id'])
                if not email:
                    continue
                
                # Skip unimportant emails (shipping, newsletters, political updates)
                if self.is_unimportant_email(email['subject'], email['body']):
                    continue
                
                # Check for urgency indicators and reference patterns
                text = (email['subject'] + ' ' + email['body']).lower()
                
                # Check if this is a reference email (important info to save)
                # Check ALL emails for reference patterns, not just important senders
                is_reference = any(pattern in text for pattern in self.reference_patterns)
                
                if is_reference:
                    self.reference_emails.append({
                        'subject': email['subject'],
                        'from': email['from'].split('<')[0].strip(),
                        'body': email['body'][:1000],  # Save more of the body
                        'date': datetime.now().strftime('%Y-%m-%d')
                    })
                
                # Only check urgency for important senders
                if self.is_important_sender(email['from']):
                    is_urgent = any(word in text for word in [
                        'urgent', 'asap', 'today', 'deadline', 'due',
                        'important', 'action required', 'respond', 'confirm'
                    ])
                    
                    if is_urgent:
                        urgent_items.append({
                            'title': email['subject'],
                            'source': f"Email from {email['from'].split('<')[0].strip()}",
                            'due': self.extract_due_date(text),
                            'priority': 'high' if 'urgent' in text or 'asap' in text else 'normal',
                            'body': email['body'][:300]  # First 300 chars for context
                        })
            
            return urgent_items[:5]  # Top 5 urgent emails
        except Exception as e:
            print(f"⚠️  Error fetching emails: {e}")
            return []
    
    def get_email_details(self, msg_id):
        """Get email details"""
        try:
            message = self.gmail_service.users().messages().get(
                userId='me',
                id=msg_id,
                format='full'
            ).execute()
            
            headers = message['payload']['headers']
            subject = next((h['value'] for h in headers if h['name'] == 'Subject'), 'No Subject')
            sender = next((h['value'] for h in headers if h['name'] == 'From'), 'Unknown')
            
            # Get body
            body = ''
            if 'parts' in message['payload']:
                for part in message['payload']['parts']:
                    if part['mimeType'] == 'text/plain' and 'data' in part['body']:
                        body = base64.urlsafe_b64decode(part['body']['data']).decode('utf-8', errors='ignore')[:500]
                        break
            elif 'body' in message['payload'] and 'data' in message['payload']['body']:
                body = base64.urlsafe_b64decode(message['payload']['body']['data']).decode('utf-8', errors='ignore')[:500]
            
            return {'subject': subject, 'from': sender, 'body': body}
        except:
            return None
    
    def extract_due_date(self, text):
        """Extract due date from text"""
        today = datetime.now()
        
        if 'today' in text or 'asap' in text:
            return today.strftime('%Y-%m-%d')
        if 'tomorrow' in text:
            return (today + timedelta(days=1)).strftime('%Y-%m-%d')
        if 'this week' in text or 'end of week' in text:
            days_until_friday = (4 - today.weekday()) % 7
            return (today + timedelta(days=days_until_friday)).strftime('%Y-%m-%d')
        
        return None
    
    def get_calendar_events(self, days=7):
        """Get calendar events for today and next N days"""
        if not self.calendar_service:
            return []
        
        try:
            now = datetime.now(timezone.utc)
            time_min = now.isoformat()
            time_max = (now + timedelta(days=days)).isoformat()
            
            events_result = self.calendar_service.events().list(
                calendarId='primary',
                timeMin=time_min,
                timeMax=time_max,
                maxResults=50,
                singleEvents=True,
                orderBy='startTime'
            ).execute()
            
            events = events_result.get('items', [])
            calendar_items = []
            
            for event in events:
                start = event['start'].get('dateTime', event['start'].get('date'))
                summary = event.get('summary', 'No title')
                
                # Skip events from excluded people (check organizer email)
                organizer = event.get('organizer', {}).get('email', '').lower()
                
                # Skip ALL events organized by ahartnet@gmail.com (Alex's calendar)
                # Events in both calendars (shared) will show since you're the organizer
                if 'ahartnet@gmail.com' in organizer:
                    continue
                
                # Parse start time
                if 'T' in start:
                    event_time = datetime.fromisoformat(start.replace('Z', '+00:00'))
                else:
                    event_time = datetime.fromisoformat(start + 'T00:00:00+00:00')
                
                # Determine if event is today or soon
                days_until = (event_time.date() - now.date()).days
                
                if days_until == 0:
                    priority = 'high'
                    due_str = 'today'
                elif days_until <= 2:
                    priority = 'high'
                    due_str = event_time.strftime('%Y-%m-%d')
                else:
                    priority = 'normal'
                    due_str = event_time.strftime('%Y-%m-%d')
                
                calendar_items.append({
                    'title': f"📅 {summary}",
                    'source': 'Google Calendar',
                    'due': due_str,
                    'priority': priority,
                    'time': event_time.strftime('%I:%M %p') if 'T' in start else 'All day',
                    'id': event['id']
                })
            
            return calendar_items
            
        except Exception as e:
            print(f"⚠️  Error fetching calendar events: {e}")
            return []
    
    def create_daily_plan_tasks(self, do_now_items, do_soon_items):
        """Create individual Todoist tasks for top DO NOW items (DakBoard compatible)"""
        try:
            headers = {'Authorization': f'Bearer {self.todoist_token}'}
            
            # Get existing tasks to avoid duplicates
            response = requests.get('https://api.todoist.com/api/v1/tasks', headers=headers)
            
            if response.status_code != 200:
                print(f"⚠️  Failed to fetch Todoist tasks: {response.status_code}")
                return False
            
            tasks = response.json()
            tasks = tasks.get('results', []) if isinstance(tasks, dict) else tasks
            
            # Delete ALL old daily plan tasks (kill and fill approach)
            deleted_count = 0
            for task in tasks:
                content = task.get('content', '')
                # Delete old format daily plan task
                if content.startswith('📋 Daily Plan -'):
                    requests.delete(f'https://api.todoist.com/api/v1/tasks/{task["id"]}', headers=headers)
                    deleted_count += 1
                # Delete ALL auto-created tasks (not just today's)
                elif content.startswith('🎯 TODAY:') or content.startswith('⏰ SOON:'):
                    requests.delete(f'https://api.todoist.com/api/v1/tasks/{task["id"]}', headers=headers)
                    deleted_count += 1
            
            if deleted_count > 0:
                print(f"   Deleted {deleted_count} old daily plan tasks")
            
            created_count = 0
            
            # Create tasks for top 5 DO NOW items (visible on DakBoard)
            for i, item in enumerate(do_now_items[:5]):
                title = item['title']
                due = item.get('due', 'today')
                time_info = f" at {item['time']}" if item.get('time') else ''
                source = item.get('source', 'Unknown')
                
                # Format: emoji + title + time (all visible on DakBoard)
                task_title = f"🎯 TODAY: {title[:80]}{time_info}"
                
                create_data = {
                    'content': task_title,
                    'due_string': due if due != 'today' else 'today',
                    'priority': 4,  # High priority (red)
                    'description': f"Source: {source}\nFrom: Daily Planner\nGenerated: {datetime.now().strftime('%I:%M %p')}"
                }
                
                create_response = requests.post(
                    'https://api.todoist.com/api/v1/tasks',
                    headers=headers,
                    json=create_data
                )
                
                if create_response.status_code == 200:
                    created_count += 1
            
            # Create summary task for DO SOON items (lower priority)
            if do_soon_items:
                soon_summary = f"⏰ SOON: {len(do_soon_items)} items this week"
                soon_details = '\n'.join([f"• {item['title'][:60]}" for item in do_soon_items[:5]])
                
                create_data = {
                    'content': soon_summary,
                    'due_string': 'this week',
                    'priority': 2,  # Medium priority (yellow)
                    'description': f"{soon_details}\n\nFrom: Daily Planner\nGenerated: {datetime.now().strftime('%I:%M %p')}"
                }
                
                requests.post('https://api.todoist.com/api/v1/tasks', headers=headers, json=create_data)
                created_count += 1
            
            print(f"✅ Created {created_count} Todoist tasks for DakBoard")
            return True
                
        except Exception as e:
            print(f"⚠️  Error creating Todoist daily plan tasks: {e}")
            return False
    
    def get_todoist_tasks(self):
        """Get tasks from Todoist using API v1"""
        try:
            headers = {'Authorization': f'Bearer {self.todoist_token}'}
            response = requests.get('https://api.todoist.com/api/v1/tasks', headers=headers)
            
            if response.status_code == 200:
                data = response.json()
                # API v1 returns paginated results
                tasks = data.get('results', []) if isinstance(data, dict) else data
                
                # Filter and prioritize
                important_tasks = []
                for task in tasks:
                    content = task.get('content', '')
                    
                    # Skip completed tasks
                    if task.get('is_completed', False):
                        continue
                    
                    # Skip auto-created daily plan tasks (to avoid duplicates)
                    if content.startswith('🎯 TODAY:') or content.startswith('⏰ SOON:') or content.startswith('📋 Daily Plan -'):
                        continue
                    
                    # Include all tasks with due dates or high priority
                    # Skip only low priority tasks without any due date
                    if task.get('priority', 1) == 1 and not task.get('due'):
                        continue
                    
                    due_date = None
                    if task.get('due'):
                        due_date = task['due'].get('date')
                    
                    important_tasks.append({
                        'title': content,
                        'source': 'Todoist',
                        'due': due_date,
                        'priority': 'high' if task.get('priority', 1) >= 3 else 'normal',
                        'id': task['id']
                    })
                
                return important_tasks
            elif response.status_code == 401:
                print(f"⚠️  Todoist authentication failed")
                print(f"   Generate test token at: https://app.todoist.com/app/settings/integrations")
                return []
            else:
                print(f"⚠️  Todoist API error {response.status_code}")
                print(f"   Response: {response.text[:150]}")
                return []
        except Exception as e:
            print(f"⚠️  Error fetching Todoist tasks: {e}")
            return []
    
    def get_google_drive_docs(self, days=7):
        """Get recently modified Google Drive documents"""
        if not self.drive_service:
            return []
        
        try:
            after_date = (datetime.now() - timedelta(days=days)).isoformat() + 'Z'
            
            results = self.drive_service.files().list(
                q=f"modifiedTime > '{after_date}' and (mimeType contains 'document' or mimeType contains 'spreadsheet' or mimeType contains 'presentation')",
                pageSize=10,
                fields="files(id, name, mimeType, modifiedTime, owners, webViewLink)"
            ).execute()
            
            files = results.get('files', [])
            docs = []
            
            for file in files:
                docs.append({
                    'name': file['name'],
                    'type': self._get_file_type(file['mimeType']),
                    'modified': file['modifiedTime'],
                    'owner': file.get('owners', [{}])[0].get('displayName', 'Unknown'),
                    'location': 'Google Drive',
                    'url': file.get('webViewLink', '')
                })
            
            return docs
        except Exception as e:
            print(f"⚠️  Error fetching Google Drive docs: {e}")
            return []
    
    def get_sharepoint_docs(self, days=7):
        """Get recently accessed SharePoint documents"""
        if not self.ms_token:
            return []
        
        try:
            headers = {'Authorization': f'Bearer {self.ms_token}'}
            
            # Get recent documents from OneDrive/SharePoint
            url = "https://graph.microsoft.com/v1.0/me/drive/recent"
            response = requests.get(url, headers=headers)
            
            if response.status_code == 200:
                items = response.json().get('value', [])
                docs = []
                
                for item in items[:10]:
                    if 'file' in item:
                        docs.append({
                            'name': item['name'],
                            'type': self._get_file_type(item.get('file', {}).get('mimeType', '')),
                            'modified': item.get('lastModifiedDateTime', ''),
                            'owner': item.get('lastModifiedBy', {}).get('user', {}).get('displayName', 'Unknown'),
                            'location': 'SharePoint/OneDrive',
                            'url': item.get('webUrl', '')
                        })
                
                return docs
            else:
                print(f"⚠️  SharePoint API error: {response.status_code}")
                return []
        except Exception as e:
            print(f"⚠️  Error fetching SharePoint docs: {e}")
            return []
    
    def _get_file_type(self, mime_type):
        """Convert MIME type to friendly file type"""
        if 'document' in mime_type or 'word' in mime_type:
            return 'Document'
        elif 'spreadsheet' in mime_type or 'excel' in mime_type:
            return 'Spreadsheet'
        elif 'presentation' in mime_type or 'powerpoint' in mime_type:
            return 'Presentation'
        elif 'pdf' in mime_type:
            return 'PDF'
        else:
            return 'File'
    
    def categorize_by_action_priority(self, items):
        """Categorize items into DO NOW, DO SOON, MONITOR using Action-Priority model"""
        today = datetime.now().date()
        tomorrow = today + timedelta(days=1)
        end_of_week = today + timedelta(days=(6 - today.weekday()))
        
        categorized = {
            'do_now': [],      # Action required today - urgent & important
            'do_soon': [],     # Action required this week - important, not urgent
            'monitor': []      # Awareness/waiting - no immediate action
        }
        
        for item in items:
            # Determine urgency and importance
            is_urgent = False
            is_important = item.get('priority') == 'high'
            
            if item.get('due'):
                try:
                    due_date = datetime.strptime(item['due'], '%Y-%m-%d').date()
                    
                    # Urgent if due today or overdue
                    if due_date <= today:
                        is_urgent = True
                    # Important if due this week
                    elif due_date <= end_of_week:
                        is_important = True
                except:
                    pass
            
            # Categorize based on urgency and importance
            if is_urgent or (is_important and item.get('priority') == 'high'):
                categorized['do_now'].append(item)
            elif is_important or item.get('due'):
                categorized['do_soon'].append(item)
            else:
                categorized['monitor'].append(item)
        
        return categorized
    
    def check_new_files(self):
        """Check for new files in Inbox and Downloads folders"""
        inbox_path = r'G:\My Drive\01_Operate\Inbox'
        downloads_path = os.path.expanduser('~\\Downloads')
        
        file_items = []
        status_messages = []
        
        # Check Inbox folder
        if os.path.exists(inbox_path):
            try:
                files = [f for f in os.listdir(inbox_path) if os.path.isfile(os.path.join(inbox_path, f))]
                if files:
                    status_messages.append(f"📁 Inbox: {len(files)} files need filing")
                    # Add as actionable item
                    file_items.append({
                        'title': f'File {len(files)} items from Inbox folder',
                        'source': 'File Organization',
                        'due': datetime.now().strftime('%Y-%m-%d'),
                        'priority': 'normal'
                    })
            except Exception as e:
                pass
        
        # Check Downloads folder
        if os.path.exists(downloads_path):
            try:
                # Only count files from last 7 days
                recent_files = []
                for f in os.listdir(downloads_path):
                    file_path = os.path.join(downloads_path, f)
                    if os.path.isfile(file_path):
                        mtime = os.path.getmtime(file_path)
                        if (datetime.now().timestamp() - mtime) < (7 * 24 * 3600):
                            recent_files.append(f)
                if recent_files:
                    status_messages.append(f"💾 Downloads: {len(recent_files)} recent files")
                    # Add as actionable item
                    file_items.append({
                        'title': f'Process {len(recent_files)} recent downloads',
                        'source': 'File Organization',
                        'due': datetime.now().strftime('%Y-%m-%d'),
                        'priority': 'normal'
                    })
            except Exception as e:
                pass
        
        return file_items, status_messages
    
    def generate_plan(self):
        """Generate comprehensive daily plan from all sources"""
        print('\n╔' + '='*60 + '╗')
        print('║' + ' '*14 + 'Daily Planner - Generating Plan' + ' '*15 + '║')
        print('╚' + '='*60 + '╝\n')
        
        # Pre-flight authentication check - log status but continue automatically
        missing_auth = []
        if not self.auth_status['gmail']:
            missing_auth.append('Gmail')
        if not self.auth_status['google_drive']:
            missing_auth.append('Google Drive')
        if not self.auth_status['microsoft']:
            missing_auth.append('Microsoft 365')
        
        if missing_auth:
            print(f'\n⚠️  Note: {len(missing_auth)} service(s) unavailable: {", ".join(missing_auth)}')
            print('   Continuing with available data sources...\n')
        
        # Check for new files
        print('📂 Checking for new files...')
        file_items, file_status = self.check_new_files()
        if file_status:
            for status in file_status:
                print(f'   {status}')
        else:
            print('   No new files to process')
        
        # Collect all items
        print('📧 Checking Gmail (last 1 month)...')
        gmail_items = self.get_gmail_emails(days=30)
        print(f'   Found {len(gmail_items)} urgent items from Gmail')
        print(f'   Found {len(self.reference_emails)} reference emails with important info')
        
        print('📧 Checking Outlook (last 1 month)...')
        outlook_items = self.get_outlook_emails(days=30)
        print(f'   Found {len(outlook_items)} urgent items from Outlook')
        
        print('📋 Fetching Todoist tasks...')
        todoist_items = self.get_todoist_tasks()
        print(f'   Found {len(todoist_items)} active tasks')
        
        print('📅 Checking Google Calendar (next 7 days)...')
        calendar_items = self.get_calendar_events(days=7)
        print(f'   Found {len(calendar_items)} upcoming events')
        
        print('📄 Checking Google Drive documents (last 7 days)...')
        gdrive_docs = self.get_google_drive_docs(days=7)
        print(f'   Found {len(gdrive_docs)} recent Google Drive files')
        
        print('📄 Checking SharePoint documents (last 7 days)...')
        sharepoint_docs = self.get_sharepoint_docs(days=7)
        print(f'   Found {len(sharepoint_docs)} recent SharePoint files')
        
        email_items = gmail_items + outlook_items
        
        # Combine and deduplicate
        all_items = email_items + todoist_items + calendar_items + file_items
        
        # Remove duplicates (same title)
        seen_titles = set()
        unique_items = []
        for item in all_items:
            title_lower = item['title'].lower()
            if title_lower not in seen_titles:
                seen_titles.add(title_lower)
                unique_items.append(item)
        
        print(f'\n✨ Total unique items: {len(unique_items)}')
        
        # Categorize by action priority
        categorized = self.categorize_by_action_priority(unique_items)
        
        # Generate plan data
        plan_data = {
            'generated': datetime.now().isoformat(),
            'do_now': categorized['do_now'],
            'do_soon': categorized['do_soon'],
            'monitor': categorized['monitor'],
            'documents': {
                'google_drive': gdrive_docs,
                'sharepoint': sharepoint_docs
            },
            'reference_emails': self.reference_emails,
            'email_summary': {
                'gmail_count': len(gmail_items),
                'outlook_count': len(outlook_items),
                'total_actionable': len(email_items),
                'reference_count': len(self.reference_emails)
            },
            'stats': {
                'total': len(unique_items),
                'do_now': len(categorized['do_now']),
                'do_soon': len(categorized['do_soon']),
                'monitor': len(categorized['monitor']),
                'documents': len(gdrive_docs) + len(sharepoint_docs)
            }
        }
        
        # Save to file
        output_file = f"daily_plan_{datetime.now().strftime('%Y%m%d')}.json"
        with open(output_file, 'w') as f:
            json.dump(plan_data, f, indent=2)
        
        print(f'\n💾 Plan saved to: {output_file}')
        
        # Display summary
        print('\n' + '='*60)
        print('DAILY PLAN SUMMARY (Action-Priority Model)')
        print('='*60)
        print(f'🎯 DO NOW ({len(categorized["do_now"])} items):')
        for item in categorized['do_now'][:5]:
            due_info = f" (due {item['due']})" if item.get('due') else ''
            print(f'   • {item["title"][:50]}{due_info}')
        
        print(f'\n⏰ DO SOON ({len(categorized["do_soon"])} items):')
        for item in categorized['do_soon'][:3]:
            due_info = f" (due {item['due']})" if item.get('due') else ''
            print(f'   • {item["title"][:50]}{due_info}')
        
        if categorized['monitor']:
            print(f'\n� MONITOR: {len(categorized["monitor"])} items')
        
        if self.reference_emails:
            print(f'\n📌 REFERENCE: {len(self.reference_emails)} important emails saved')
            for ref in self.reference_emails[:3]:
                print(f'   • {ref["subject"][:50]} (from {ref["from"]})')
        
        # Create individual Todoist tasks for DakBoard visibility
        print('\n📋 Creating Todoist tasks for DakBoard...')
        self.create_daily_plan_tasks(categorized['do_now'], categorized['do_soon'])
        
        print('\n' + '='*60)
        print('Creating Amplenote Action Plan...')
        print('='*60)
        
        # Automatically sync to Amplenote
        try:
            import subprocess
            result = subprocess.run(
                ['node', 'sync_plan_to_amplenote.js'],
                cwd=os.path.dirname(os.path.abspath(__file__)),
                capture_output=True,
                text=True,
                encoding='utf-8',
                errors='replace'
            )
            
            if result.returncode == 0:
                print('\n✅ Amplenote note created successfully!')
                # Extract URL from output if available
                if result.stdout:
                    for line in result.stdout.split('\n'):
                        if 'https://www.amplenote.com/notes/' in line:
                            print(f'   {line.strip()}')
            else:
                print(f'\n⚠️  Amplenote sync failed: {result.stderr}')
        except Exception as e:
            print(f'\n⚠️  Could not sync to Amplenote: {e}')
        
        return plan_data

def main():
    planner = DailyPlanner()
    planner.generate_plan()

if __name__ == '__main__':
    main()
